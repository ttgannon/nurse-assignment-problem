# ─── Server ───────────────────────────────────────────────────────────────────

# Express server port
PORT=3000

# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nursify"

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET="replace-me-with-a-long-random-string"

# Comma-separated list of allowed CORS origins (frontend URL)
ALLOWED_ORIGINS="http://localhost:5174"

NODE_ENV="development"

# ─── FHIR / SMART on FHIR ────────────────────────────────────────────────────

# OAuth client credentials — register your app with each FHIR server vendor.
# For public clients (PKCE only), leave FHIR_CLIENT_SECRET blank.
# For confidential clients (Epic, Cerner production), set the secret here —
# it NEVER leaves the server.
FHIR_CLIENT_ID="your-smart-client-id"
FHIR_CLIENT_SECRET=""

# The URL that the FHIR authorization server redirects back to AFTER login.
# Must match exactly what is registered in your SMART app configuration.
# This is a FRONTEND URL — the frontend catches the code and POSTs it to
# the backend /api/auth/callback endpoint.
FHIR_REDIRECT_URI="http://localhost:5174/auth/callback"

# ─── Frontend (Vite) — create a .env file in the project root ────────────────
# These variables are exposed to the browser (VITE_ prefix).
# Copy them into a root-level .env file alongside your vite.config.ts.

# VITE_API_BASE_URL="http://localhost:3000"
# VITE_FHIR_REDIRECT_URI="http://localhost:5174/auth/callback"
